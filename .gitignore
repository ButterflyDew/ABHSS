# Local agent/editor state
/.agents/
/.codex/
/.vs/
/.vscode/
.DS_Store
Thumbs.db
*.lnk

# Build trees and native artifacts
/build/
/build_external/
/result/
/results/
/tmp/
/.tmp_*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
*.exe
*.dll
*.lib
*.obj
*.pdb
*.ilk
*.exp

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Large graph/query payloads. Keep the tiny smoke inputs, deterministic
# generator, and per-dataset provenance manifests in Git.
/data/*
!/data/example/
!/data/hack_dpbf_vs_test4/
!/data/generate_queries_for_noGPU4GST.py
!/data/*/
/data/*/*
!/data/example/**
!/data/hack_dpbf_vs_test4/**
!/data/*/dataset_manifest.json

# Downloaded source graphs and CSR payloads. The README, manifests, hashes,
# small author-query CSV files, and download/verification scripts remain.
/data_origin/*.g
/data_origin/*.in
/data_origin/*.bin
/data_origin/*.pdf

# The related-query panel is deterministically regenerable from the frozen
# selection JSON; its expanded text files account for roughly 239 MiB.
/experiment_data/gpu4gst_panel/**/*.txt

# Vendored dependencies include unlicensed author repositories, Boost, SCIP,
# build products, and a nested Git object pack. Publish acquisition metadata
# instead of redistributing those trees.
/third_party/*
!/third_party/README.md

# Local paper copies include copyrighted publications and an unpublished
# manuscript. Documentation cites them but the public repository must not.
/docs/papers/

# Official-upstream benchmark freeze.  Raw archives, extracted dumps and
# conversion scratch space are reproducible but far too large for Git.  Keep
# the catalog, download manifest, build manifests and documentation tracked.
/data_sources/official/**/raw/
/data_sources/official/**/extracted/
/data_sources/official/**/work/
/data_sources/official/**/*.part
/data_sources/official/**/*.tmp

# The converted official interface data is regenerated from the frozen raw
# hashes.  Per-dataset manifests remain tracked through the general exception
# above; the multi-gigabyte graph/query payloads do not.
/data/official-*/**/graph.txt
/data/official-*/**/query*.txt
/data/official-*/**/candidate_groups.txt

# Keep only compact identity/normalization manifests for the nested official
# interface directories.  Graphs, groups, URI maps and expanded query payloads
# are rebuilt from the frozen official hashes.
!/data/official-*/
!/data/official-*/*/
/data/official-*/*/*
!/data/official-*/*/dataset_manifest.json
!/data/official-*/*/source_normalization.json
!/data/official-*/*/source_query_manifest.json
!/data/official-*/*/build_manifest.json
!/data/official-*/*/build_stats.json

# Official paper panels are deterministic expansions of the tracked JSON/CSV
# selection manifests and generators; do not publish their large text payloads.
/experiment_data/official_latest/**/*.txt

# Retired draft panels are intentionally outside the A/B/C paper matrix. Keep
# them locally for engineering archaeology without publishing contradictory
# manifests alongside the frozen formal panels.
/experiment_data/official_latest/controlled/
/experiment_data/official_latest/imdb_label_frequency/
